package br.ulbra.listaperfume;

import java.util.ArrayList;

public class GerenciadorPerfumes {

    private ArrayList<String> perfume;
    private ArrayList<String> copOriginal;

    public GerenciadorPerfumes(ArrayList<String> perfume, ArrayList<String> copOriginal) {
        this.perfume = perfume;
        this.copOriginal = copOriginal;
    }

    public ArrayList<String> getPerfume() {
        return perfume;
    }

    public void setPerfume(ArrayList<String> perfume) {
        this.perfume = perfume;
    }

    public ArrayList<String> getCopOriginal() {
        return copOriginal;
    }

    public void setCopOriginal(ArrayList<String> copOriginal) {
        this.copOriginal = copOriginal;
    }
//Cadastro

    public void cadastro(String nome) {
        perfume.add(nome);
        System.out.println("Perfume cadastrado com sucesso");
    }
//Alterar

    public void alterar(String nomeAntigo, String nomeNovo) {
        int index = perfume.indexOf(nomeAntigo);
        if (index != -1) {
            perfume.set(index, nomeNovo);
            System.out.println("Nome alterado com sucesso");
        } else {
            System.out.println("Perfume não encontrado");
        }
        //Excluir
    public void excluir(String nome) {
        if (perfume.remove(nome)) {
            System.out.println("Perfume Removido");
        }
    }

}

